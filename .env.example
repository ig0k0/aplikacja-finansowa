DATABASE_URL=./data/app.db
SESSION_SECRET=change-me-before-use

# VPS / HTTPS (za Caddy lub nginx)
# APP_URL=https://finanse.example.com
# TRUST_PROXY=1
# COOKIE_SECURE=1
# FORCE_HSTS=1
# LOGIN_RATE_LIMIT_MAX=8
# LOGIN_RATE_LIMIT_DISABLED=0
BACKUP_ENCRYPTION_KEY=change-me-backup-key
BACKUP_DESTINATION=./backups
# Opcjonalnie: przy npm run backup:scheduled — usun pliki starsze niz N dni (0 = wylacz)
# BACKUP_RETENTION_DAYS=14

# AI (OpenAI-compatible, np. Ollama http://127.0.0.1:11434/v1)
AI_MODE=disabled
# AI_MODE=local
# AI_BASE_URL=http://127.0.0.1:11434/v1
# AI_MODEL=llama3.2
# AI_API_KEY=
# AI_CONFIDENCE_AUTO=0.85
# AI_CONFIDENCE_REVIEW=0.6

SEED_USER_1_LOGIN=igor
SEED_USER_1_DISPLAY_NAME=Igor
SEED_USER_1_PASSWORD=change-me-user-1

SEED_USER_2_LOGIN=user2
SEED_USER_2_DISPLAY_NAME=Uzytkownik 2
SEED_USER_2_PASSWORD=change-me-user-2
